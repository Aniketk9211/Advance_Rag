# --- Required ---

# OpenAI: used for all LLM calls (gpt-4o-mini) and for OpenAIEmbeddings
OPENAI_API_KEY=

# Tavily: used by the web_search fallback node
TAVILY_API_KEY=

# LangSmith: required for tracing AND for pulling the "rlm/rag-prompt" prompt
# from the LangSmith hub at import time (src/graph/chain/generation.py)
LANGSMITH_API_KEY=

# --- Optional (LangSmith tracing configuration) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="Corrective RAG"

# --- Qdrant vector store ---
# Defaults to the docker-compose service name; override only if running
# against a Qdrant instance outside of docker-compose (e.g. localhost).
# QDRANT_URL=http://qdrant:6333
# QDRANT_COLLECTION_NAME=rag-qdrant

# --- Present in current .env but unused by any code today (legacy/reserved) ---
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# PINECONE_API_KEY=
# INDEX_NAME=
